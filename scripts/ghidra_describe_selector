#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

[[ $# -eq 3 ]] || {
  echo "Usage: ghidra_describe_selector <project_name> <program_name> <selector>" >&2
  exit 1
}

project_name="$1"
program_name="$2"
selector="$3"
export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"

if [[ ! -f "$export_dir/objc_metadata.json" || ! -f "$export_dir/strings.json" ]]; then
  "$SCRIPT_DIR/ghidra_export_apple_bundle" "$project_name" "$program_name" >/dev/null
fi

trace_json='{}'

if [[ "${GHIDRA_RE_DISABLE_LIVE_BRIDGE:-0}" != "1" ]] && ghidra_re_project_has_live_session "$project_name" "$program_name"; then
  trace_json="$("$SCRIPT_DIR/ghidra_bridge_selector_trace" \
    "selector=$selector" \
    "project=$project_name" \
    "program=$program_name" \
    "exact=true" 2>/dev/null || printf '{}')"
fi

"$(ghidra_re_python)" "$SCRIPT_DIR/ghidra_objc_surface_backend.py" \
  --mode selector \
  --export-dir "$export_dir" \
  --query "$selector" \
  --trace-json "$trace_json"
