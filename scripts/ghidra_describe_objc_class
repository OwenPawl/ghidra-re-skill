#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

[[ $# -eq 3 ]] || {
  echo "Usage: ghidra_describe_objc_class <project_name> <program_name> <class_name>" >&2
  exit 1
}

project_name="$1"
program_name="$2"
class_name="$3"
export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"

if [[ ! -f "$export_dir/objc_metadata.json" || ! -f "$export_dir/symbols.json" ]]; then
  "$SCRIPT_DIR/ghidra_export_apple_bundle" "$project_name" "$program_name" >/dev/null
fi

python3 - "$export_dir/objc_metadata.json" "$export_dir/symbols.json" "$class_name" <<'PY'
import json, pathlib, sys

objc = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
symbols = json.loads(pathlib.Path(sys.argv[2]).read_text(encoding="utf-8"))
class_name = sys.argv[3]

methods = [m for m in objc.get("methods", []) if m.get("class_name") == class_name]
symbol_hits = [s for s in symbols.get("objc_related", []) if class_name in s.get("name", "")]

payload = {
    "class_name": class_name,
    "declared": class_name in objc.get("classes", []),
    "metaclass_declared": class_name in objc.get("metaclasses", []),
    "methods": methods,
    "symbol_hits": symbol_hits,
}
print(json.dumps(payload, indent=2))
PY
