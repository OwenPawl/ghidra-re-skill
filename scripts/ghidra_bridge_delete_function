#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_delete_function <function_or_address>
EOF
}

[[ $# -eq 1 ]] || {
  usage >&2
  exit 1
}

body="$(ghidra_re_bridge_json_from_kv write=true destructive=true function="$1")"
"$SCRIPT_DIR/ghidra_bridge_call" /function/delete "$body"
