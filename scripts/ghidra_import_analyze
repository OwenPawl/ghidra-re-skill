#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_import_analyze <binary|source:name:/path/in/image> [project_name]
EOF
}

[[ $# -ge 1 && $# -le 2 ]] || {
  usage >&2
  exit 1
}

binary_path="$(ghidra_re_resolve_binary_spec "$1" cache || true)"
[[ -f "$binary_path" ]] || ghidra_re_die "binary not found or source spec could not be resolved: $1"

project_name="${2:-$(ghidra_re_sanitize_name "$(basename "$binary_path")")}"
program_name="$(ghidra_re_program_name_from_binary "$binary_path")"
project_location="$(ghidra_re_project_location "$project_name")"
log_dir="$(ghidra_re_log_dir "$project_name")"
timestamp="$(ghidra_re_timestamp)"
log_file="$log_dir/import-${timestamp}.log"
script_log="$log_dir/import-${timestamp}.script.log"
script_path="$(ghidra_re_script_path)"
analyze_headless="$(ghidra_re_analyze_headless_path)"

ghidra_re_require_tools
ghidra_re_export_env
ghidra_re_ensure_workspace
mkdir -p "$project_location" "$log_dir"

optional_args=()
while IFS= read -r -d '' item; do
  optional_args+=("$item")
done < <(ghidra_re_optional_headless_args)

cmd=(
  "$analyze_headless"
  "$project_location"
  "$project_name"
  -import "$binary_path"
  -overwrite
  -scriptPath "$script_path"
)
if ghidra_re_flag_enabled "${GHIDRA_IMPORT_DEMANGLE:-1}"; then
  cmd+=(-postScript DemangleAllScript.java)
fi
if [[ ${#optional_args[@]} -gt 0 ]]; then
  cmd+=("${optional_args[@]}")
fi
cmd+=(
  -log "$log_file"
  -scriptlog "$script_log"
)

"${cmd[@]}"

summarize_import_log() {
  local log_file="$1"
  local script_log="$2"
  local unresolved_count=0
  local unresolved_system=0
  local unresolved_private=0
  local unresolved_swift=0
  local unresolved_other=0
  local symbol_length_failures=0
  local demangle_failures=0

  if [[ -f "$log_file" ]]; then
    unresolved_count="$(grep -c -- '-> not found in project' "$log_file" || true)"
    symbol_length_failures="$(grep -c 'Symbol name exceeds maximum length' "$log_file" || true)"
    read -r unresolved_system unresolved_private unresolved_swift unresolved_other <<<"$(
      python3 - "$log_file" <<'PY'
import re
import sys

system = private = swift = other = 0
with open(sys.argv[1], "r", encoding="utf-8", errors="replace") as handle:
    for line in handle:
        if "-> not found in project" not in line:
            continue
        match = re.search(r"\[(.+?)\]", line)
        path = match.group(1) if match else ""
        if path.startswith("/usr/lib/swift/"):
            swift += 1
        elif path.startswith("/System/Library/PrivateFrameworks/"):
            private += 1
        elif path.startswith("/System/Library/Frameworks/") or path.startswith("/usr/lib/"):
            system += 1
        else:
            other += 1
print(system, private, swift, other)
PY
    )"
  fi

  if [[ -f "$script_log" ]]; then
    demangle_failures="$(grep -c 'Unable to demangle:' "$script_log" || true)"
  fi

  if (( unresolved_count > 0 || symbol_length_failures > 0 || demangle_failures > 0 )); then
    printf 'Import warnings summary:\n'
    if (( unresolved_count > 0 )); then
      printf '  unresolved external programs: %d (system=%d private=%d swift_runtime=%d other=%d)\n' \
        "$unresolved_count" "$unresolved_system" "$unresolved_private" "$unresolved_swift" "$unresolved_other"
    fi
    if (( symbol_length_failures > 0 )); then
      printf '  overlength symbol failures: %d\n' "$symbol_length_failures"
    fi
    if (( demangle_failures > 0 )); then
      printf '  demangle failures: %d\n' "$demangle_failures"
    fi
  fi
}

summarize_import_log "$log_file" "$script_log"

printf 'Imported %s\n' "$binary_path"
printf 'Project: %s\n' "$project_name"
printf 'Program: %s\n' "$program_name"
printf 'Project file: %s\n' "$(ghidra_re_project_file "$project_name")"
printf 'Log: %s\n' "$log_file"
printf 'Script log: %s\n' "$script_log"
