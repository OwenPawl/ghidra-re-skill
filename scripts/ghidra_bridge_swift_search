#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_swift_search <type_or_method> [session=<id>|project=<name>|program=<name>]
   or: ghidra_bridge_swift_search query=<type_or_method> [key=value ...]
EOF
}

[[ $# -ge 1 ]] || {
  usage >&2
  exit 1
}

query=""
selector_args=()
for arg in "$@"; do
  case "$arg" in
    query=*)
      query="${arg#query=}"
      ;;
    session=*|project=*|program=*)
      selector_args+=("$arg")
      ;;
    *)
      if [[ -z "$query" ]]; then
        query="$arg"
      else
        selector_args+=("$arg")
      fi
      ;;
  esac
done

[[ -n "$query" ]] || ghidra_re_die "missing Swift query"
python_cmd="$(ghidra_re_python)" || ghidra_re_die "python is required"

session_body='{}'
if [[ ${#selector_args[@]} -gt 0 ]]; then
  session_body="$(ghidra_re_bridge_json_from_kv "${selector_args[@]}")"
fi
session_json="$("$SCRIPT_DIR/ghidra_bridge_call" /session "$session_body")"

read -r project_name program_name <<<"$(
"$python_cmd" - "$session_json" <<'PY'
import json, sys
payload = json.loads(sys.argv[1])
result = payload.get("result", {})
repository = result.get("repository", {})
context = result.get("current_context", {})
print(repository.get("project_name", ""), context.get("program_name", ""))
PY
)"

[[ -n "$project_name" && -n "$program_name" ]] || \
  ghidra_re_die "could not resolve project/program from bridge session"

export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"
if [[ ! -f "$export_dir/swift_metadata.json" ]]; then
  "$SCRIPT_DIR/ghidra_export_apple_bundle" "$project_name" "$program_name" >/dev/null
fi

search_json="$(
"$python_cmd" "$SCRIPT_DIR/ghidra_swift_surface_backend.py" \
  search \
  "$export_dir/swift_metadata.json" \
  "$export_dir/objc_metadata.json" \
  "$export_dir/symbols.json" \
  "$export_dir/strings.json" \
  "$query"
)"

canonical_address="$(
"$python_cmd" - "$search_json" <<'PY'
import json, sys
payload = json.loads(sys.argv[1])
for item in payload.get("matches", []):
    address = item.get("canonical_address") or item.get("address") or ""
    if address:
        print(address)
        break
PY
)"

analyze_json='null'
if [[ -n "$canonical_address" ]]; then
  analyze_args=("address=$canonical_address")
  if [[ ${#selector_args[@]} -gt 0 ]]; then
    analyze_args+=("${selector_args[@]}")
  fi
  analyze_json="$("$SCRIPT_DIR/ghidra_bridge_analyze_target" "${analyze_args[@]}")"
fi

"$python_cmd" - "$session_json" "$search_json" "$analyze_json" <<'PY'
import json, sys
session = json.loads(sys.argv[1])
search = json.loads(sys.argv[2])
analyze = None if sys.argv[3] == "null" else json.loads(sys.argv[3])
payload = {
    "query": search.get("query", ""),
    "session": session.get("result", {}),
    "search": search,
    "live_analysis": analyze.get("result", analyze) if analyze else None,
}
print(json.dumps(payload, indent=2))
PY
