#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_patch_bytes <address> <hex_bytes>
EOF
}

[[ $# -eq 2 ]] || {
  usage >&2
  exit 1
}

body="$(ghidra_re_bridge_json_from_kv write=true destructive=true address="$1" bytes="$2")"
"$SCRIPT_DIR/ghidra_bridge_call" /patch/bytes "$body"
