#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_clear_listing <start> [end] [mode]
Modes:
  all
  code
  data
EOF
}

[[ $# -ge 1 && $# -le 3 ]] || {
  usage >&2
  exit 1
}

start="$1"
end="${2:-$1}"
mode="${3:-all}"
body="$(ghidra_re_bridge_json_from_kv write=true destructive=true start="$start" end="$end" mode="$mode")"
"$SCRIPT_DIR/ghidra_bridge_call" /listing/clear "$body"
