#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_bridge_patch_instruction <address> <assembly>
EOF
}

[[ $# -ge 2 ]] || {
  usage >&2
  exit 1
}

address="$1"
shift
assembly="$*"
body="$(ghidra_re_bridge_json_from_kv write=true destructive=true address="$address" assembly="$assembly")"
"$SCRIPT_DIR/ghidra_bridge_call" /patch/instruction "$body"
