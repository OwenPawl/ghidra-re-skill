#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

[[ $# -eq 3 ]] || {
  echo "Usage: ghidra_trace_classref <project_name> <program_name> <class_name>" >&2
  exit 1
}

project_name="$1"
program_name="$2"
class_name="$3"
export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"

if [[ ! -f "$export_dir/objc_metadata.json" || ! -f "$export_dir/symbols.json" ]]; then
  "$SCRIPT_DIR/ghidra_export_apple_bundle" "$project_name" "$program_name" >/dev/null
fi

xref_json='{}'

if [[ "${GHIDRA_RE_DISABLE_LIVE_BRIDGE:-0}" != "1" ]] && ghidra_re_project_has_live_session "$project_name" "$program_name"; then
  xref_json="$("$SCRIPT_DIR/ghidra_bridge_symbols_xrefs" \
    "symbol=_OBJC_CLASS_\$_${class_name}" \
    "project=$project_name" \
    "program=$program_name" 2>/dev/null || printf '{}')"
fi

"$(ghidra_re_python)" "$SCRIPT_DIR/ghidra_objc_surface_backend.py" \
  --mode classref \
  --export-dir "$export_dir" \
  --query "$class_name" \
  --trace-json "$xref_json"
