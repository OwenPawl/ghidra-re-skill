#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_objc_message_flow <project_name> <program_name> <selector> [class=<ClassName>]
EOF
}

[[ $# -ge 3 ]] || {
  usage >&2
  exit 1
}

project_name="$1"
program_name="$2"
selector="$3"
shift 3

class_name=""
extra_args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    class=*)
      class_name="${1#class=}"
      ;;
    *)
      extra_args+=("$1")
      ;;
  esac
  shift
done

export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"

if [[ ! -f "$export_dir/objc_metadata.json" || ! -f "$export_dir/symbols.json" || ! -f "$export_dir/strings.json" ]]; then
  "$SCRIPT_DIR/ghidra_export_apple_bundle" "$project_name" "$program_name" >/dev/null
fi

trace_json='{}'
if [[ "${GHIDRA_RE_DISABLE_LIVE_BRIDGE:-0}" != "1" ]] && ghidra_re_project_has_live_session "$project_name" "$program_name"; then
  bridge_args=(
    "selector=$selector"
    "project=$project_name"
    "program=$program_name"
    "exact=true"
  )
  if [[ ${#extra_args[@]} -gt 0 ]]; then
    bridge_args+=("${extra_args[@]}")
  fi
  trace_json="$("$SCRIPT_DIR/ghidra_bridge_selector_trace" "${bridge_args[@]}" 2>/dev/null || printf '{}')"
fi

args=(
  --mode message_flow
  --export-dir "$export_dir"
  --query "$selector"
  --trace-json "$trace_json"
)
if [[ -n "$class_name" ]]; then
  args+=(--class-name "$class_name")
fi

"$(ghidra_re_python)" "$SCRIPT_DIR/ghidra_objc_surface_backend.py" "${args[@]}"
