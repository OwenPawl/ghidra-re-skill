#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_swift_surface_report <project_name> <program_name> [query] [format=json|markdown]
   or: ghidra_swift_surface_report <project_name> <program_name> query=<query> [format=json|markdown]
EOF
}

[[ $# -ge 2 ]] || {
  usage >&2
  exit 1
}

project_name="$1"
program_name="$2"
shift 2

query=""
format="json"

while [[ $# -gt 0 ]]; do
  case "$1" in
    query=*)
      query="${1#query=}"
      ;;
    format=*)
      format="${1#format=}"
      ;;
    json|markdown)
      if [[ -z "$query" ]]; then
        format="$1"
      else
        ghidra_re_die "unsupported argument: $1"
      fi
      ;;
    *)
      if [[ -z "$query" ]]; then
        query="$1"
      else
        ghidra_re_die "unsupported argument: $1"
      fi
      ;;
  esac
  shift
done

export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"
if [[ ! -f "$export_dir/swift_metadata.json" ]]; then
  "$SCRIPT_DIR/ghidra_export_apple_bundle" "$project_name" "$program_name" >/dev/null
fi

python_cmd="$(ghidra_re_python)" || ghidra_re_die "python is required"
"$python_cmd" "$SCRIPT_DIR/ghidra_swift_surface_backend.py" \
  report \
  "$export_dir/swift_metadata.json" \
  "$export_dir/objc_metadata.json" \
  "$export_dir/symbols.json" \
  "$export_dir/strings.json" \
  "$query" \
  "$format"
