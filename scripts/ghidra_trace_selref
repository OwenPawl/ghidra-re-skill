#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

[[ $# -eq 3 ]] || {
  echo "Usage: ghidra_trace_selref <project_name> <program_name> <selector_or_address>" >&2
  exit 1
}

project_name="$1"
program_name="$2"
target="$3"

if [[ "$target" =~ ^0x[0-9a-fA-F]+$ || "$target" =~ ^[0-9a-fA-F]+$ ]]; then
  "$SCRIPT_DIR/ghidra_bridge_call" /references "$(ghidra_re_bridge_json_from_kv "project=$project_name" "program=$program_name" "address=$target")"
  exit 0
fi

matches_json="$("$SCRIPT_DIR/ghidra_bridge_strings_search" "project=$project_name" "program=$program_name" "query=$target" "exact=true")"

python3 - "$matches_json" <<'PY'
import json, sys

payload = json.loads(sys.argv[1])
result = payload.get("result", {}) if isinstance(payload, dict) else {}
matches = result.get("matches", [])
print(json.dumps({
    "selector": result.get("query", ""),
    "matches": matches,
}, indent=2))
PY
