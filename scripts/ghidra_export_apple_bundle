#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_export_apple_bundle <project_name> <program_name>
EOF
}

[[ $# -eq 2 ]] || {
  usage >&2
  exit 1
}

project_name="$1"
program_name="$2"

ghidra_re_require_tools
ghidra_re_export_env
ghidra_re_ensure_workspace
ghidra_re_require_project "$project_name"

export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"
log_dir="$(ghidra_re_log_dir "$project_name")"
timestamp="$(ghidra_re_timestamp)"
log_file="$log_dir/export-${timestamp}.log"
script_log="$log_dir/export-${timestamp}.script.log"
script_path="$(ghidra_re_script_path)"
analyze_headless="$(ghidra_re_analyze_headless_path)"
working_project_name="$project_name"
working_project_root="$(ghidra_re_project_location "$project_name")"
snapshot_root=""

mkdir -p "$export_dir" "$log_dir"

cleanup() {
  if [[ -n "$snapshot_root" && -d "$snapshot_root" ]]; then
    rm -rf "$snapshot_root"
  fi
}
trap cleanup EXIT

optional_args=()
while IFS= read -r -d '' item; do
  optional_args+=("$item")
done < <(ghidra_re_optional_headless_args)

analysis_args=()
case "${GHIDRA_EXPORT_ANALYZE:-0}" in
  1|true|yes|on)
    ;;
  0|false|no|off|"")
    analysis_args=(-noanalysis)
    ;;
  *)
    ghidra_re_die "unsupported GHIDRA_EXPORT_ANALYZE: ${GHIDRA_EXPORT_ANALYZE}"
    ;;
esac

cmd=(
  "$analyze_headless"
  "$working_project_root"
  "$working_project_name"
  -process "$program_name"
  -scriptPath "$script_path"
)
if [[ ${#analysis_args[@]} -gt 0 ]]; then
  cmd+=("${analysis_args[@]}")
fi
if [[ ${#optional_args[@]} -gt 0 ]]; then
  cmd+=("${optional_args[@]}")
fi
if ghidra_re_flag_enabled "${GHIDRA_EXPORT_DEMANGLE:-1}"; then
  cmd+=(-postScript DemangleAllScript.java)
fi
cmd+=(-postScript ExportAppleBundle.java "outdir=${export_dir}")
cmd+=(
  -log "$log_file"
  -scriptlog "$script_log"
)

if ghidra_re_project_has_live_session "$project_name" "$program_name" || ghidra_re_project_has_lock_files "$project_name"; then
  session_json="$(ghidra_re_bridge_session_json "" "$project_name" "$program_name" 2>/dev/null || true)"
  if [[ -n "$session_json" ]]; then
    save_message="$(
      python3 - "$session_json" <<'PY'
import json, sys
try:
    payload = json.loads(sys.argv[1])
except Exception:
    payload = {}
repository = payload.get("result", {}).get("repository", {}) if isinstance(payload, dict) else {}
if repository.get("changed") and repository.get("can_save"):
    print("save")
PY
    )"
    if [[ "$save_message" == "save" ]] && ghidra_re_flag_enabled "${GHIDRA_EXPORT_SAVE_LIVE:-1}"; then
      if save_output="$("$SCRIPT_DIR/ghidra_bridge_save" "project=$project_name" "program=$program_name" "description=CodexBridge: save before export snapshot" 2>/dev/null)"; then
        printf 'ghidra-re: saved dirty live session before snapshot export.\n' >&2
        session_json="$(ghidra_re_bridge_session_json "" "$project_name" "$program_name" 2>/dev/null || true)"
      else
        printf 'ghidra-re: failed to save dirty live session before snapshot export; proceeding with on-disk state.\n' >&2
      fi
    fi
    warning_message="$(
      python3 - "$session_json" <<'PY'
import json, sys
try:
    payload = json.loads(sys.argv[1])
except Exception:
    payload = {}
repository = payload.get("result", {}).get("repository", {}) if isinstance(payload, dict) else {}
if repository.get("changed"):
    print("ghidra-re: live GUI session has unsaved changes; snapshot export will use the on-disk project state and may miss recent bridge mutations.")
PY
    )"
    if [[ -n "$warning_message" ]]; then
      printf '%s\n' "$warning_message" >&2
    fi
  fi
  IFS='|' read -r snapshot_root working_project_name _ <<<"$(ghidra_re_create_readonly_project_snapshot "$project_name" "export-$program_name")"
  working_project_root="$snapshot_root/$working_project_name"
  cmd[1]="$working_project_root"
  cmd[2]="$working_project_name"
  cmd+=(-readOnly)
fi

"${cmd[@]}"

expected_files=(
  "$export_dir/program_summary.json"
  "$export_dir/objc_metadata.json"
  "$export_dir/swift_metadata.json"
  "$export_dir/function_inventory.json"
  "$export_dir/symbols.json"
  "$export_dir/strings.json"
)
for output_path in "${expected_files[@]}"; do
  [[ -f "$output_path" ]] || ghidra_re_die "expected export file is missing: $output_path"
done

printf 'Exported Apple bundle for %s/%s\n' "$project_name" "$program_name"
printf 'Export dir: %s\n' "$export_dir"
printf 'Files:\n'
printf '  %s\n' "$export_dir/program_summary.json"
printf '  %s\n' "$export_dir/objc_metadata.json"
printf '  %s\n' "$export_dir/swift_metadata.json"
printf '  %s\n' "$export_dir/function_inventory.json"
printf '  %s\n' "$export_dir/symbols.json"
printf '  %s\n' "$export_dir/strings.json"
printf 'Log: %s\n' "$log_file"
printf 'Script log: %s\n' "$script_log"
