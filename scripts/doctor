#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

status_ok=0
status_warn=0

print_status() {
  local level="$1"
  local label="$2"
  local value="${3:-}"
  printf '%-8s %s' "$level" "$label"
  if [[ -n "$value" ]]; then
    printf ': %s' "$value"
  fi
  printf '\n'
}

record_ok() {
  status_ok=$((status_ok + 1))
  print_status "OK" "$1" "${2:-}"
}

record_warn() {
  status_warn=$((status_warn + 1))
  print_status "WARN" "$1" "${2:-}"
}

show_candidate() {
  local label="$1"
  local value="$2"
  if [[ -n "$value" ]]; then
    print_status "INFO" "$label" "$value"
  fi
}

configured_ghidra="${GHIDRA_INSTALL_DIR:-}"
configured_jdk="${GHIDRA_JDK:-}"
detected_ghidra="$(ghidra_re_detect_ghidra_dir || true)"
detected_jdk="$(ghidra_re_detect_jdk_dir || true)"
python_cmd="$(ghidra_re_python || true)"
bash_cmd="$(command -v bash || true)"

printf 'ghidra-re doctor\n'
printf 'Skill root: %s\n' "$GHIDRA_RE_ROOT"
printf 'Platform: %s\n' "$GHIDRA_RE_PLATFORM"
printf 'User config: %s\n' "$GHIDRA_RE_USER_CONFIG"
printf 'Skill-local config: %s\n' "$GHIDRA_RE_SKILL_CONFIG"
printf '\n'

if ghidra_re_valid_ghidra_dir "$configured_ghidra"; then
  record_ok "Configured Ghidra" "$configured_ghidra"
else
  record_warn "Configured Ghidra" "${configured_ghidra:-not set or invalid}"
fi

if ghidra_re_valid_jdk_dir "$configured_jdk"; then
  record_ok "Configured JDK" "$configured_jdk"
else
  record_warn "Configured JDK" "${configured_jdk:-not set or invalid}"
fi

show_candidate "Detected Ghidra candidate" "$detected_ghidra"
show_candidate "Detected JDK candidate" "$detected_jdk"
show_candidate "Detected Python" "$python_cmd"
show_candidate "Detected Bash" "$bash_cmd"
show_candidate "Shared notes repo" "$GHIDRA_NOTES_REPO"
show_candidate "Shared notes issue number" "${GHIDRA_NOTES_ISSUE_NUMBER:-}"
show_candidate "Shared notes root" "$GHIDRA_NOTES_ROOT"

for path in \
  "$GHIDRA_WORKSPACE" \
  "$GHIDRA_PROJECTS_DIR" \
  "$GHIDRA_EXPORTS_DIR" \
  "$GHIDRA_LOGS_DIR" \
  "$GHIDRA_INVESTIGATIONS_DIR" \
  "$GHIDRA_SOURCES_CACHE_DIR"
do
  if [[ -d "$path" ]]; then
    record_ok "Directory exists" "$path"
  else
    record_warn "Directory missing" "$path"
  fi
done

for notes_asset in \
  "$GHIDRA_RE_ROOT/scripts/ghidra_notes_add" \
  "$GHIDRA_RE_ROOT/scripts/ghidra_notes_sync" \
  "$GHIDRA_RE_ROOT/scripts/ghidra_notes_pull" \
  "$GHIDRA_RE_ROOT/scripts/ghidra_notes_status" \
  "$GHIDRA_RE_ROOT/scripts/ghidra_notes_remediate" \
  "$GHIDRA_RE_ROOT/scripts/ghidra_notes_open_shared" \
  "$GHIDRA_RE_ROOT/scripts/ghidra_notes_backend.py"
do
  if [[ -f "$notes_asset" ]]; then
    record_ok "Shared-notes asset present" "$notes_asset"
  else
    record_warn "Shared-notes asset missing" "$notes_asset"
  fi
done

for script_name in \
  "$GHIDRA_CUSTOM_SCRIPTS_DIR/BugHuntSupport.java" \
  "$GHIDRA_CUSTOM_SCRIPTS_DIR/ExportAppleBundle.java" \
  "$GHIDRA_CUSTOM_SCRIPTS_DIR/ExportEntrypoints.java" \
  "$GHIDRA_CUSTOM_SCRIPTS_DIR/ExportSinks.java" \
  "$GHIDRA_CUSTOM_SCRIPTS_DIR/TriageBugPaths.java" \
  "$GHIDRA_CUSTOM_SCRIPTS_DIR/ExportFunctionDossier.java" \
  "$GHIDRA_CUSTOM_SCRIPTS_DIR/ApplyFinding.java" \
  "$GHIDRA_CUSTOM_SCRIPTS_DIR/DecompileFunction.java" \
  "$GHIDRA_CUSTOM_SCRIPTS_DIR/ExportXrefs.java"
do
  if [[ -f "$script_name" ]]; then
    record_ok "Script present" "$script_name"
  else
    record_warn "Script missing" "$script_name"
  fi
done

for script_name in \
  "$GHIDRA_RE_ROOT/scripts/ghidra_bridge_build" \
  "$GHIDRA_RE_ROOT/scripts/ghidra_bridge_install" \
  "$GHIDRA_RE_ROOT/scripts/ghidra_bridge_arm" \
  "$GHIDRA_RE_ROOT/scripts/ghidra_bridge_disarm" \
  "$GHIDRA_RE_ROOT/scripts/ghidra_bridge_status" \
  "$GHIDRA_RE_ROOT/scripts/ghidra_bridge_call" \
  "$GHIDRA_RE_BRIDGE_EXTENSION_DIR/src/main/java/codexghidrabridge/CodexBridgePlugin.java" \
  "$GHIDRA_RE_BRIDGE_EXTENSION_DIR/src/main/java/codexghidrabridge/CodexBridgeService.java" \
  "$GHIDRA_RE_BRIDGE_EXTENSION_DIR/src/main/java/codexghidrabridge/CodexBridgeProvider.java" \
  "$GHIDRA_RE_BRIDGE_EXTENSION_DIR/ghidra_scripts/EnableCodexBridge.java"
do
  if [[ -f "$script_name" ]]; then
    record_ok "Bridge asset present" "$script_name"
  else
    record_warn "Bridge asset missing" "$script_name"
  fi
done

bridge_settings_dir="$(ghidra_re_bridge_settings_dir || true)"
show_candidate "Detected Ghidra settings dir" "$bridge_settings_dir"
if [[ -n "$bridge_settings_dir" ]]; then
  if [[ -d "$(ghidra_re_bridge_installed_dir)" ]]; then
    record_ok "Bridge installed dir" "$(ghidra_re_bridge_installed_dir)"
  else
    record_warn "Bridge installed dir" "$(ghidra_re_bridge_installed_dir)"
  fi
  if [[ -d "$(ghidra_re_bridge_tools_dir)" ]]; then
    record_ok "Ghidra tools dir" "$(ghidra_re_bridge_tools_dir)"
  else
    record_warn "Ghidra tools dir" "$(ghidra_re_bridge_tools_dir)"
  fi
fi

if [[ -f "$GHIDRA_RE_BRIDGE_SESSION_FILE" ]]; then
  record_ok "Bridge session file" "$GHIDRA_RE_BRIDGE_SESSION_FILE"
else
  show_candidate "Bridge session file" "$GHIDRA_RE_BRIDGE_SESSION_FILE"
fi

if [[ -f "$GHIDRA_RE_BUG_HUNT_MANIFEST" ]]; then
  record_ok "Bug-hunt manifest" "$GHIDRA_RE_BUG_HUNT_MANIFEST"
else
  record_warn "Bug-hunt manifest" "$GHIDRA_RE_BUG_HUNT_MANIFEST"
fi

if [[ -f "$GHIDRA_RE_SOURCE_REGISTRY_FILE" ]]; then
  record_ok "Source registry" "$GHIDRA_RE_SOURCE_REGISTRY_FILE"
else
  show_candidate "Source registry" "$GHIDRA_RE_SOURCE_REGISTRY_FILE"
fi

ghidra_re_notes_init_files
if [[ -f "$GHIDRA_NOTES_CONFIG_FILE" ]]; then
  record_ok "Shared-notes config" "$GHIDRA_NOTES_CONFIG_FILE"
else
  record_warn "Shared-notes config" "$GHIDRA_NOTES_CONFIG_FILE"
fi
if [[ -f "$GHIDRA_NOTES_STATE_FILE" ]]; then
  record_ok "Shared-notes state" "$GHIDRA_NOTES_STATE_FILE"
else
  record_warn "Shared-notes state" "$GHIDRA_NOTES_STATE_FILE"
fi
if ghidra_re_has_gh_cli; then
  if ghidra_re_gh_authenticated; then
    record_ok "GitHub CLI auth" "authenticated"
  else
    record_warn "GitHub CLI auth" "gh is installed but not authenticated"
  fi
else
  record_warn "GitHub CLI auth" "gh is not installed"
fi

printf '\n'
if [[ "$status_warn" -eq 0 ]]; then
  print_status "READY" "ghidra-re looks ready to use"
else
  print_status "ACTION" "Run scripts/bootstrap to auto-configure this machine"
fi
