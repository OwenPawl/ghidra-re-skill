#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_objc_surface_report <project_name> <program_name> [format=json|markdown]
EOF
}

[[ $# -ge 2 && $# -le 3 ]] || {
  usage >&2
  exit 1
}

project_name="$1"
program_name="$2"
format="${3-json}"
export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"

if [[ ! -f "$export_dir/objc_metadata.json" || ! -f "$export_dir/symbols.json" || ! -f "$export_dir/strings.json" ]]; then
  "$SCRIPT_DIR/ghidra_export_apple_bundle" "$project_name" "$program_name" >/dev/null
fi

"$(ghidra_re_python)" "$SCRIPT_DIR/ghidra_objc_surface_backend.py" \
  --mode surface \
  --export-dir "$export_dir" \
  --format "$format"
