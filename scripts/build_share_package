#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

output_path="${1:-$PWD/ghidra-re-skill-share-$(date '+%Y%m%d-%H%M%S').zip}"
stage_root="$(mktemp -d "${TMPDIR:-/tmp}/ghidra-re-share.XXXXXX")"
package_root="$stage_root/ghidra-re-share"
package_skill_dir="$package_root/ghidra-re"

cleanup() {
  rm -rf "$stage_root"
}
trap cleanup EXIT

mkdir -p "$package_root"
rsync -a \
  --exclude '.git' \
  --exclude '.git/' \
  --exclude '.DS_Store' \
  --exclude '__MACOSX' \
  --exclude '.gradle/' \
  --exclude 'build/' \
  "$GHIDRA_RE_ROOT/" \
  "$package_skill_dir/"

cat >"$package_root/install-ghidra-re.sh" <<'EOF'
#!/usr/bin/env bash
#
# ghidra-re share-package installer.
#
# Delegates to the host-agnostic scripts/install_skill inside the packaged
# skill so that the same script surface that powers a git checkout also
# powers share-package installs.
#
# Usage:
#   ./install-ghidra-re.sh                       # auto-detect host(s)
#   ./install-ghidra-re.sh --host codex          # force Codex only
#   ./install-ghidra-re.sh --host claude         # force Claude Code only
#   ./install-ghidra-re.sh --host both           # install into every host
#   ./install-ghidra-re.sh --skip-smoke-test     # forwarded to bootstrap

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PACKAGE_SKILL_DIR="$SCRIPT_DIR/ghidra-re"

if [[ ! -x "$PACKAGE_SKILL_DIR/scripts/install_skill" ]]; then
  printf 'install-ghidra-re: %s/scripts/install_skill is missing or not executable\n' \
    "$PACKAGE_SKILL_DIR" >&2
  exit 1
fi

exec "$PACKAGE_SKILL_DIR/scripts/install_skill" --source "$PACKAGE_SKILL_DIR" "$@"
EOF

cat >"$package_root/README.txt" <<'EOF'
ghidra-re share package

1. Unzip this archive.
2. Run ./install-ghidra-re.sh
3. The installer copies the skill into every detected skill host
   (~/.codex/skills/ghidra-re for Codex, ~/.claude/skills/ghidra-re
   for Claude Code) and runs scripts/bootstrap for each target.

To force a single host:
  ./install-ghidra-re.sh --host codex
  ./install-ghidra-re.sh --host claude
  ./install-ghidra-re.sh --host both

If bootstrap cannot auto-detect Ghidra or Java 21, run:
  <install-target>/scripts/doctor

The generated machine-local config lives at:
  ~/.config/ghidra-re/config.env

The live bridge registry lives at:
  ~/.config/ghidra-re/bridge-sessions/
  ~/.config/ghidra-re/bridge-current.json
  ~/.config/ghidra-re/bridge-requests/

If Ghidra was already running before install, restart it once or run:
  EnableCodexBridge.java
from Ghidra's Script Manager.
EOF

chmod +x "$package_root/install-ghidra-re.sh" "$package_skill_dir"/scripts/*

mkdir -p "$(dirname "$output_path")"
rm -f "$output_path"
(
  cd "$stage_root"
  zip -qr "$output_path" "ghidra-re-share"
)

printf 'Built share package: %s\n' "$output_path"
