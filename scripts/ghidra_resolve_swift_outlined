#!/usr/bin/env bash
#
# ghidra_resolve_swift_outlined
#
# Renames _OUTLINED_FUNCTION_* stubs to descriptive names and marks
# pure ARC/copy helpers as inline so Ghidra's decompiler folds them away.
#
# This dramatically improves decompile output for Swift-heavy Apple
# binaries — especially dyld-extracted frameworks like WorkflowKit —
# where the Swift compiler extracted shared ARC/copy/move snippets as
# anonymous outlined helpers.  Without renaming and inlining, every
# caller shows dozens of opaque _OUTLINED_FUNCTION_0() calls that hide
# the real control flow.
#
# The script runs ResolveSwiftOutlined.java headlessly against an
# existing Ghidra project.  If the project is currently open in the
# GUI (live bridge session), it operates on a read-only snapshot so
# the GUI session is undisturbed, then offers to sync the renames back
# via the live bridge's rename endpoint in batches.
#
# Usage:
#   ghidra_resolve_swift_outlined <project_name> <program_name> [key=value ...]
#
# Key=value options:
#   dry_run=true       Classify and report without writing renames.
#   inline=false       Skip marking helpers as inline (default: true).
#   skip_stubs=true    Skip unresolved import auth stubs (default: false = rename).
#   verbose=true       Print each rename to the log.
#
# Output:
#   <exports>/<project_name>/<program_name>/swift_outlined_resolved.json
#
# After a successful run the export bundle's function_inventory.json is
# NOT automatically regenerated; run ghidra_export_apple_bundle again
# to refresh it if needed.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  sed -n '3,43p' "$0"
}

[[ $# -ge 2 ]] || {
  usage >&2
  exit 1
}

project_name="$1"
program_name="$2"
shift 2

# Remaining args are forwarded to the Java script
extra_script_args=("$@")

ghidra_re_require_tools
ghidra_re_export_env
ghidra_re_ensure_workspace
ghidra_re_require_project "$project_name"

export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"
log_dir="$(ghidra_re_log_dir "$project_name")"
timestamp="$(ghidra_re_timestamp)"
log_file="$log_dir/swift-outlined-${timestamp}.log"
script_log="$log_dir/swift-outlined-${timestamp}.script.log"
script_path="$(ghidra_re_script_path)"
analyze_headless="$(ghidra_re_analyze_headless_path)"

mkdir -p "$export_dir" "$log_dir"

working_project_name="$project_name"
working_project_root="$(ghidra_re_project_location "$project_name")"
snapshot_root=""

cleanup() {
  if [[ -n "$snapshot_root" && -d "$snapshot_root" ]]; then
    rm -rf "$snapshot_root"
  fi
}
trap cleanup EXIT

optional_args=()
while IFS= read -r -d '' item; do
  optional_args+=("$item")
done < <(ghidra_re_optional_headless_args)

# Build the script args to pass through
script_arg_str="output_dir=${export_dir}"
for extra in "${extra_script_args[@]}"; do
  script_arg_str="${script_arg_str}' '${extra}"
done

# If the project is open in the GUI, use a read-only snapshot.
# The headless run will rename in the snapshot; we then offer to
# apply renames via the live bridge.
use_readonly=0
if ghidra_re_project_has_live_session "$project_name" "$program_name" || \
   ghidra_re_project_has_lock_files "$project_name"; then
  IFS='|' read -r snapshot_root working_project_name _ \
    <<<"$(ghidra_re_create_readonly_project_snapshot "$project_name" "swift-outlined-$program_name")"
  working_project_root="$snapshot_root/$working_project_name"
  use_readonly=1
  printf 'ghidra-re: project locked by GUI — running on read-only snapshot\n'
  printf '  Renames will be applied via live bridge after headless run.\n'
fi

cmd=(
  "$analyze_headless"
  "$working_project_root"
  "$working_project_name"
  -process "$program_name"
  -noanalysis
  -scriptPath "$script_path"
)
if [[ ${#optional_args[@]} -gt 0 ]]; then
  cmd+=("${optional_args[@]}")
fi
if [[ "$use_readonly" -eq 1 ]]; then
  cmd+=(-readOnly)
fi
cmd+=(-postScript ResolveSwiftOutlined.java)
# Pass each extra arg as a separate script argument
cmd+=("output_dir=${export_dir}")
for extra in "${extra_script_args[@]}"; do
  cmd+=("$extra")
done
cmd+=(
  -log "$log_file"
  -scriptlog "$script_log"
)

"${cmd[@]}"

report_file="$export_dir/swift_outlined_resolved.json"
[[ -f "$report_file" ]] || ghidra_re_die "expected report file is missing: $report_file"

# Parse and print summary
python3 - "$report_file" <<'PYEOF'
import sys, json

report_path = sys.argv[1]
with open(report_path) as f:
    r = json.load(f)

print(f"\nSwift outlined resolution complete for {r['program_name']}")
print(f"  Total _OUTLINED_FUNCTION_* found: {r['total_outlined_functions']}")
print(f"  Renamed:       {r['renamed']}")
print(f"  Marked inline: {r['inlined']}")
print(f"  Skipped stubs: {r['skipped_stubs']}")
print(f"  Dry run:       {r['dry_run']}")
print(f"\n  Category breakdown:")
for cat, count in r.get('categories', {}).items():
    print(f"    {cat:<30s} {count:>5d}")
print(f"\nReport: {report_path}")
PYEOF

# If we operated on a read-only snapshot but renames were requested,
# apply them back to the live project via the bridge rename endpoint.
if [[ "$use_readonly" -eq 1 ]]; then
  # Check if dry_run was set
  dry_run_flag=0
  for extra in "${extra_script_args[@]}"; do
    [[ "$extra" == "dry_run=true" ]] && dry_run_flag=1
  done

  if [[ "$dry_run_flag" -eq 0 ]]; then
    printf '\nghidra-re: applying renames to live project via bridge...\n'
    "$SCRIPT_DIR/ghidra_bridge_open" "$project_name" "$program_name" >/dev/null
    session_file="$(ghidra_re_bridge_resolve_session_file "" "$project_name" "$program_name")"
    bridge_url="$(ghidra_re_bridge_read_value_from_file "$session_file" bridge_url)"
    bridge_token="$(ghidra_re_bridge_read_value_from_file "$session_file" token)"
    python3 - "$report_file" "$bridge_url" "$bridge_token" <<'PYEOF'
import json
import sys
import urllib.error
import urllib.request

report_path = sys.argv[1]
bridge_url = sys.argv[2].rstrip("/")
bridge_token = sys.argv[3]
with open(report_path) as f:
    r = json.load(f)

renames = r.get("renames", [])
ok = 0
fail = 0
skipped = 0
sample_failures = []
total = len(renames)

for index, rec in enumerate(renames, 1):
    if rec.get("old_name") == rec.get("new_name"):
        skipped += 1
        continue

    body = json.dumps(
        {
            "write": True,
            "address": rec["entry"],
            "rename": rec["new_name"],
            "inline": bool(rec.get("marked_inline", False)),
        }
    ).encode("utf-8")
    request = urllib.request.Request(
        f"{bridge_url}/edit/function-signature",
        data=body,
        headers={
            "Authorization": f"Bearer {bridge_token}",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(request, timeout=30) as response:
            response.read()
        ok += 1
    except urllib.error.HTTPError as exc:
        fail += 1
        if len(sample_failures) < 5:
            sample_failures.append({
                "entry": rec["entry"],
                "new_name": rec["new_name"],
                "status": exc.code,
                "body": exc.read().decode("utf-8", errors="replace").strip(),
            })
    except Exception as exc:
        fail += 1
        if len(sample_failures) < 5:
            sample_failures.append({
                "entry": rec["entry"],
                "new_name": rec["new_name"],
                "error": str(exc),
            })

    if index % 250 == 0:
        print(f"  Bridge progress: {index}/{total} processed, {ok} ok, {fail} failed, {skipped} unchanged", flush=True)

print(f"  Bridge renames: {ok} ok, {fail} failed, {skipped} unchanged")
if sample_failures:
    print("  Sample failures:")
    for item in sample_failures:
        print("   -", json.dumps(item, sort_keys=True))
PYEOF

    session_json="$(ghidra_re_bridge_session_json "" "$project_name" "$program_name" 2>/dev/null || true)"
    if [[ -n "$session_json" ]]; then
      warning_message="$(
        python3 - "$session_json" <<'PY'
import json, sys
try:
    payload = json.loads(sys.argv[1])
except Exception:
    payload = {}
repository = payload.get("result", {}).get("repository", {}) if isinstance(payload, dict) else {}
if repository.get("changed") and repository.get("can_save"):
    print("ghidra-re: live project now has unsaved bridge changes; snapshot exports will not reflect these mutations until the GUI program is saved.")
PY
      )"
      if [[ -n "$warning_message" ]]; then
        printf '%s\n' "$warning_message"
      fi
    fi
  fi
fi

printf '\nghidra-re: outline resolution done.\n'
printf 'Log:        %s\n' "$log_file"
printf 'Script log: %s\n' "$script_log"
printf 'Report:     %s\n' "$report_file"
printf '\n'
printf 'Next step: run ghidra_export_apple_bundle to regenerate function_inventory.json\n'
printf '           with the new names reflected.\n'
