#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

usage() {
  cat <<'EOF'
Usage: ghidra_import_macos_framework </System/.../Framework.framework/Framework> [project_name] [copy=cache|direct] [source=<name>]
   or: ghidra_import_macos_framework </System/.../Framework.framework> [project_name] [copy=cache|direct] [source=<name>]
EOF
}

[[ $# -ge 1 ]] || {
  usage >&2
  exit 1
}

requested_path="$1"
shift
project_name=""
copy_mode="cache"
source_name=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    copy=*)
      copy_mode="${1#copy=}"
      ;;
    source=*)
      source_name="${1#source=}"
      ;;
    *)
      if [[ -z "$project_name" ]]; then
        project_name="$1"
      else
        ghidra_re_die "unsupported argument: $1"
      fi
      ;;
  esac
  shift
done

ghidra_re_ensure_workspace
python_cmd="$(ghidra_re_python)" || ghidra_re_die "python is required"
resolved_json="$(
  "$python_cmd" "$SCRIPT_DIR/ghidra_macos_import_backend.py" \
    resolve \
    "$requested_path" \
    "$GHIDRA_RE_SOURCE_REGISTRY_FILE" \
    "$GHIDRA_SOURCES_CACHE_DIR" \
    "$copy_mode" \
    "$source_name"
)"

read -r resolved_path strategy source_label cache_identity <<<"$(
"$python_cmd" - "$resolved_json" <<'PY'
import json, sys
payload = json.loads(sys.argv[1])
print(
    payload.get("resolved_path", ""),
    payload.get("strategy", ""),
    payload.get("source_name", ""),
    payload.get("cache_identity", ""),
)
PY
)"

[[ -f "$resolved_path" ]] || ghidra_re_die "resolved import target is not a file: $resolved_path"

if [[ -z "$project_name" ]]; then
  base_name="$(basename "$resolved_path")"
  suffix=""
  if [[ -n "$cache_identity" ]]; then
    suffix="_${cache_identity:0:8}"
  else
    suffix="_$(printf '%s' "$requested_path" | shasum | awk '{print substr($1,1,8)}')"
  fi
  project_name="$(ghidra_re_sanitize_name "${base_name}${suffix}")"
fi

printf 'Resolved macOS image path: %s\n' "$requested_path"
printf 'Resolved binary: %s\n' "$resolved_path"
printf 'Strategy: %s\n' "$strategy"
if [[ -n "$source_label" ]]; then
  printf 'Source: %s\n' "$source_label"
fi

"$SCRIPT_DIR/ghidra_import_analyze" "$resolved_path" "$project_name"
