#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

body="$(ghidra_re_bridge_json_from_kv "$@")"
response="$("$SCRIPT_DIR/ghidra_bridge_call" /session "$body")"
printf '%s' "$response" | /usr/bin/ruby -rjson -e '
payload = JSON.parse(STDIN.read)
STDOUT.write(JSON.pretty_generate(payload.fetch("result").fetch("current_context")))
'
