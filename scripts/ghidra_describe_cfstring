#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

[[ $# -eq 3 ]] || {
  echo "Usage: ghidra_describe_cfstring <project_name> <program_name> <query_or_address>" >&2
  exit 1
}

project_name="$1"
program_name="$2"
query="$3"
export_dir="$(ghidra_re_export_dir "$project_name" "$program_name")"

if [[ ! -f "$export_dir/strings.json" ]]; then
  "$SCRIPT_DIR/ghidra_export_apple_bundle" "$project_name" "$program_name" >/dev/null
fi

if [[ "$query" =~ ^0x[0-9a-fA-F]+$ || "$query" =~ ^[0-9a-fA-F]+$ ]] && ghidra_re_project_has_live_session "$project_name" "$program_name"; then
  "$SCRIPT_DIR/ghidra_bridge_data_get" "project=$project_name" "program=$program_name" "address=$query"
  exit 0
fi

python3 - "$export_dir/strings.json" "$query" <<'PY'
import json, pathlib, sys

strings = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
query = sys.argv[2].lower()
matches = []
for item in strings.get("strings", []):
    if item.get("artifact_type") != "cfstring":
        continue
    value = item.get("value", "")
    if query in value.lower() or query == item.get("address", "").lower():
        matches.append(item)
payload = {"query": sys.argv[2], "matches": matches}
print(json.dumps(payload, indent=2))
PY
